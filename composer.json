{
    "name": "briqpay/module-payments-hyva-checkout",
    "description": "Briqpay Payments module for Hyvä Checkout, providing seamless integration with Briqpay payment gateway.",
    "license": "OSL-3.0 OR AFL-3.0",
    "authors": [
        {
            "name": "Michiel Gerritsen",
            "email": "michiel@controlaltdelete.nl"
        }
    ],
    "require": {
        "php": ">=8.1",
        "briqpay/module-payments": "*",
        "hyva-themes/magento2-hyva-checkout": "^1.3.8",
        "hyva-themes/magento2-compat-module-fallback": "*"
    },
    "autoload": {
        "psr-4": {
