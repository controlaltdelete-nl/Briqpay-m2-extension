<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd"
>
    <body>
        <referenceBlock name="checkout.payment.methods">
            <block name="checkout.payment.method.briqpay"
                   as="briqpay"
                   template="Briqpay_PaymentsHyvaCheckout::checkout/payment/briqpay.phtml"
            >
                <arguments>
                    <argument name="magewire" xsi:type="object">
                        Briqpay\PaymentsHyvaCheckout\Magewire\Payment\Method\Briqpay
                    </argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>
